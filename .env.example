# === ChemTrace Configuration ===

# Paths (defaults work out of the box; override for custom layouts)
CHEMTRACE_INPUT_DIR=./data/sample_invoices
CHEMTRACE_OUTPUT_DIR=./output
CHEMTRACE_CHROMA_DIR=./chroma_db

# Ollama (LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=180

# RAG parameters
RAG_TOP_K=4
RAG_TEMPERATURE=0.2
RAG_MAX_TOKENS=555

# Embedding model (sentence-transformers, runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Logging
LOG_LEVEL=INFO

# VSME Export
# CHEMTRACE_VSME_TEMPLATE=data/vsme_templates/VSME-Digital-Template-1_2_0.xlsx
